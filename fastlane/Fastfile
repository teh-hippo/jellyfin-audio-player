default_platform(:ios)

package = load_json(json_path: "package.json")

# Fork override (teh-hippo):
# - Stripped upstream `before_all` (hard-coded leinelissen's ASC API key id,
#   plus `get_certificates` / `get_provisioning_profile` which we don't want
#   to call: the cert and profile are pre-imported on the runner via
#   .github/workflows/release.yml).
# - Stripped upstream `after_all` Sentry uploads (we have no Sentry org).
# - Upstream :release / :beta / :build / :screenshots lanes kept structurally
#   intact but are unused by us — :teh_hippo_beta is the only lane our
#   release workflow calls.

platform :ios do
    lane :teh_hippo_beta do
        # ASC API key from env (no .p8 file written to disk).
        app_store_connect_api_key(
            key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
            issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
            key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY")
        )

        # Manual signing tied to the pre-imported cert + profile.
        update_code_signing_settings(
            use_automatic_signing: false,
            targets: ["Fintunes"],
            build_configurations: ["Release"],
            path: "ios/Fintunes.xcodeproj",
            team_id: ENV.fetch("APPLE_TEAM_ID"),
            bundle_identifier: "io.tehhippo.fintunes",
            code_sign_identity: "Apple Distribution",
            profile_uuid: ENV.fetch("APPLE_PROVISIONING_PROFILE_UUID")
        )

        increment_version_number(
            version_number: package["version"],
            xcodeproj: "ios/Fintunes.xcodeproj"
        )

        # Build number must beat TestFlight's existing builds for the same
        # version (upstream has shipped 2.5.0 builds up to 1119 historically).
        next_build = latest_testflight_build_number(
            version: package["version"],
            app_identifier: "io.tehhippo.fintunes",
            initial_build_number: 0
        ).to_i + 1
        increment_build_number(
            build_number: next_build,
            xcodeproj: "ios/Fintunes.xcodeproj"
        )

        build_app(
            scheme: "Fintunes",
            workspace: "ios/Fintunes.xcworkspace",
            export_method: "app-store",
            output_directory: "build",
            export_options: {
                provisioningProfiles: {
                    "io.tehhippo.fintunes" => "Fintunes - App Store"
                }
            }
        )

        upload_to_testflight(
            uses_non_exempt_encryption: false,
            skip_waiting_for_build_processing: true
        )
    end

    lane :release do
        build_app(
            scheme: "Fintunes",
            output_directory: "build",
            workspace: "ios/Fintunes.xcworkspace",
            export_method: "app-store",
        )
        upload_to_app_store(
            precheck_include_in_app_purchases: false
        )
    end

    lane :beta do
        build_app(
            scheme: "Fintunes",
            output_directory: "build",
            workspace: "ios/Fintunes.xcworkspace",
            export_method: "app-store",
        )
        upload_to_testflight()
    end

    lane :build do
        build_app(
            scheme: "Fintunes",
            output_directory: "build",
            workspace: "ios/Fintunes.xcworkspace",
            export_method: "app-store",
        )
    end

    lane :ci_build do
        build_app(
            scheme: "Fintunes",
            output_directory: "build",
            workspace: "ios/Fintunes.xcworkspace",
            skip_codesigning: true,
            skip_archive: true,
            skip_package_ipa: true
        )
    end

    lane :screenshots do
        capture_screenshots
        # upload_to_app_store
    end
end

platform :android do
    desc "Generate beta build"

    lane :build do
        gradle(
            task: "assemble",
            build_type: "Release",
            project_dir: "android"
        )
    end

    lane :beta do
        android_set_version_name(
            version_name: package["version"],
            gradle_file: "android/app/build.gradle"
        )
        android_set_version_code(
            gradle_file: "android/app/build.gradle"
        )
        gradle(
            task: "assemble",
            build_type: "Release",
            project_dir: "android"
        )
        gradle(
            task: "bundle",
            build_type: "Release",
            project_dir: "android"
        )
        upload_to_play_store(
            track: "beta",
            skip_upload_apk: true
        )
    end

    lane :release do
        android_set_version_name(
            version_name: package["version"],
            gradle_file: "android/app/build.gradle"
        )
        android_set_version_code(
            gradle_file: "android/app/build.gradle"
        )
        gradle(
            task: "bundle",
            build_type: "Release",
            project_dir: "android"
        )
        upload_to_play_store(
            skip_upload_apk: true
        )
    end
end
